/* pages/profile/profile.wxss */
.container {
  padding: 20rpx;
}

.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 30rpx;
}

.nickname-input {
  width: 100%;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.btn-save {
  background: #4CAF50;
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  width: 80%;
}

/* 区块样式 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.btn-action {
  background: #f5f5f5;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  color: #333;
}

.setting-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 0;
}

.btn-logout {
  background: #f44336;
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}
