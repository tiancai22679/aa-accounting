/* pages/settlement/settlement.wxss */
.container {
  padding: 20rpx;
}

.total-section {
  background: linear-gradient(135deg, #2196F3, #0D47A1);
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  color: white;
  text-align: center;
}

.total-label {
  font-size: 30rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 20rpx;
}

.total-amount {
  font-size: 60rpx;
  font-weight: bold;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

/* 余额列表 */
.balance-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.balance-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 30rpx;
  border-radius: 12rpx;
}

.balance-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.balance-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #2196F3;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.balance-name {
  font-size: 32rpx;
  color: #333;
}

.balance-right {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.balance-paid, .balance-owed {
  font-size: 26rpx;
  color: #666;
}

.balance-net {
  font-size: 32rpx;
  font-weight: 600;
}

.balance-net.positive {
  color: #4CAF50;
}

.balance-net.negative {
  color: #f44336;
}

/* 结算方案 */
.settlement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.settlement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 30rpx;
  border-radius: 12rpx;
}

.settlement-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex: 1;
}

.settlement-from, .settlement-to {
  font-size: 30rpx;
  color: #333;
}

.settlement-arrow {
  font-size: 28rpx;
  color: #999;
}

.settlement-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #f44336;
}

.btn-confirm {
  background: #4CAF50;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 结算历史 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
}

.history-text {
  font-size: 28rpx;
  color: #333;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #666;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}
