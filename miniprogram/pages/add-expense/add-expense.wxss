/* pages/add-expense/add-expense.wxss */
.container {
  padding: 20rpx;
}

.amount-section {
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.currency {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.amount-input {
  flex: 1;
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
}

/* 区块样式 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.split-mode {
  font-size: 28rpx;
  color: #4CAF50;
}

/* 类别网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(20% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f9f9f9;
}

.category-item.active {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* 描述输入 */
.desc-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

/* 日期选择 */
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.arrow {
  color: #999;
}

/* 成员网格 */
.member-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.member-item {
  width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f9f9f9;
  border: 2rpx solid transparent;
}

.member-item.selected {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.member-name {
  font-size: 24rpx;
  color: #666;
}

/* 提交按钮 */
.submit-section {
  padding: 40rpx 0;
}

.btn-submit {
  background: #4CAF50;
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 36rpx;
  padding: 24rpx 0;
}
